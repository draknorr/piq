{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm --filter @publisheriq/ingestion... build",
    "dockerfilePath": null,
    "watchPatterns": [
      "/packages/ingestion/**",
      "/packages/database/**",
      "/packages/shared/**",
      "/packages/qdrant/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @publisheriq/ingestion ccu-demo-railway-worker",
    "healthcheckPath": null,
    "healthcheckTimeout": null,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
