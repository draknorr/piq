# Cube.js Environment Variables

# Database connection (TigerData / Timescale PostgreSQL)
CUBEJS_DB_HOST=your-tiger-host.tigerdata.io
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=tsdb
CUBEJS_DB_USER=tsdbadmin
CUBEJS_DB_PASS=your-database-password
CUBEJS_DB_APPLICATION_NAME=publisheriq-cube

# API Secret for JWT validation (generate with: openssl rand -hex 32)
CUBEJS_API_SECRET=your-secret-key-here

# Development mode (enables Playground UI)
CUBEJS_DEV_MODE=false

# Cache driver (memory for low volume, redis for scale)
CUBEJS_CACHE_AND_QUEUE_DRIVER=memory

# Pre-aggregations schema
CUBEJS_PRE_AGGREGATIONS_SCHEMA=cube_pre_aggs

# Background refresh scheduler check interval
CUBEJS_SCHEDULED_REFRESH_TIMER_SECONDS=300
