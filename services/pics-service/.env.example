# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Optional: route PICS change-history rows to Tiger/R2.
PICS_CHANGE_HISTORY_TARGET=supabase
PICS_CHANGE_HISTORY_TIGER_URL=postgresql://...

# Optional: route PICS latest-state app/relationship/sync cursor writes to Tiger.
PICS_LATEST_STATE_TARGET=supabase
PICS_LATEST_STATE_TIGER_URL=postgresql://...

TIGER_PRIMARY_URL=postgresql://...
CHANGE_INTEL_ARCHIVE_TARGET=object_storage
CHANGE_INTEL_ARCHIVE_BUCKET=publisheriq-change-intel-archive
CHANGE_INTEL_ARCHIVE_PREFIX=production/change-intel
CHANGE_INTEL_ARCHIVE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CHANGE_INTEL_ARCHIVE_REGION=auto
CHANGE_INTEL_ARCHIVE_ACCESS_KEY_ID=...
CHANGE_INTEL_ARCHIVE_SECRET_ACCESS_KEY=...
CHANGE_INTEL_ARCHIVE_FORCE_PATH_STYLE=true

# Service mode: "bulk_sync" or "change_monitor"
MODE=change_monitor

# Port for health checks (Railway injects this)
PORT=8080

# Bulk sync options (used when MODE=bulk_sync)
BULK_BATCH_SIZE=200
BULK_REQUEST_DELAY=0.5

# Change monitor options (used when MODE=change_monitor)
POLL_INTERVAL=30
PROCESS_BATCH_SIZE=100
MAX_QUEUE_SIZE=10000

# One-time PICS change-history backfill options.
PICS_CHANGE_HISTORY_BACKFILL_DRY_RUN=true
PICS_CHANGE_HISTORY_BACKFILL_BATCH_SIZE=500
# PICS_CHANGE_HISTORY_BACKFILL_LIMIT=1000
PICS_CHANGE_HISTORY_BACKFILL_MIN_ID=0
PICS_CHANGE_HISTORY_BACKFILL_SURFACES=snapshots,events

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
